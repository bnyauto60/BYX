# --- Supabase (base de données, stockage, authentification) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Moteurs IA disponibles (renseigner ceux que vous utilisez) ---
# BYX est indépendant du fournisseur : voir src/lib/ai/router.ts
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Fournisseur par défaut si aucune règle spécifique ne s'applique : openai | anthropic | mock
AI_DEFAULT_PROVIDER=mock

# Attribution des tâches par provider (JSON). Laisser vide = utilise AI_DEFAULT_PROVIDER partout.
# Exemple : {"structuration":"openai","diagnostic":"anthropic","rapport":"anthropic","video":"openai"}
AI_TASK_ROUTING={}

# --- Application ---
NEXT_PUBLIC_APP_NAME=BYX
NEXT_PUBLIC_WORKSHOP_NAME="BNY Auto"
NEXT_PUBLIC_WORKSHOP_CITY="Chevrières (60)"
